# ── Flask ──────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ── Database ───────────────────────────────────────────────────────────────────
# Defaults to SQLite (../database.db) if not set.
DATABASE_URL=

# ── Redis (optional — needed only for Celery background tasks) ─────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP — needed for appointment reminders / welcome emails) ───────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Default Admin Account (auto-created on first run) ─────────────────────────
ADMIN_EMAIL=admin@hospital.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Administrator
